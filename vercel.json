{
  "functions": {
    "api/submit.js": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/process.js": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/result.js": {
      "maxDuration": 10,
      "memory": 128
    },
    "api/upload-url.js": {
      "maxDuration": 10,
      "memory": 128
    },
    "api/leads.js": {
      "maxDuration": 10,
      "memory": 128
    },
    "api/lead.js": {
      "maxDuration": 10,
      "memory": 128
    },
    "api/save-lead.js": {
      "maxDuration": 10,
      "memory": 128
    },
    "api/cleanup.js": {
      "maxDuration": 15,
      "memory": 128
    },
    "api/admin.js": {
      "maxDuration": 10,
      "memory": 128
    },
    "api/client.js": {
      "maxDuration": 10,
      "memory": 128
    },
    "api/billing.js": {
      "maxDuration": 15,
      "memory": 256
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, Upstash-Signature, X-Client-Secret" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/widget/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
